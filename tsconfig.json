{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "next-env.d.ts",
    "**/*.mjs",
    ".next/types/**/*.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "src/lib/expCalculator.test.ts",
    "src/lib/gameLogic.test.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}

