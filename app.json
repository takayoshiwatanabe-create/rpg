{
  "expo": {
    "name": "シュクダイ・クエスト 〜勇者の宿題なぎ倒しRPG〜",
    "slug": "rpg",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app_icon.png",
    "scheme": "rpg",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "「シュクダイ・クエスト」は、子供たちの毎日の宿題をRPGの冒険に変える画期的なアプリです。宿題をクリアすると経験値やゴールドを獲得し、勇者をレベルアップさせ、新たなスキルを習得できます。保護者も進捗を管理でき、子供の学習意欲を自然に引き出します。さあ、宿題を倒して世界を救う勇者になろう！日々の学習が、ワクワクする冒険に変わる！",
    "privacyPolicyUrl": "https://www.yourdomain.com/privacy-policy",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zerocode.rpg",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "このアプリでは、広告表示のためにユーザーの行動データを追跡する場合があります。これにより、より関連性の高い広告を提供できます。",
        "NSLocationWhenInUseUsageDescription": "このアプリは、現在地情報を使用しません。",
        "NSPhotoLibraryUsageDescription": "このアプリは、写真ライブラリへのアクセスを必要としません。",
        "NSCameraUsageDescription": "このアプリは、カメラへのアクセスを必要としません.",
        "SKAdNetworkItems": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.zerocode.rpg",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "src"
        }
      ],
      "expo-localization",
      "expo-notifications",
      "expo-tracking-transparency"
    ],
    "locales": {
      "ja": "./locales/ja.json",
      "en": "./locales/en.json",
      "zh": "./locales/zh.json",
      "ko": "./locales/ko.json",
      "es": "./locales/es.json",
      "fr": "./locales/fr.json",
      "de": "./locales/de.json",
      "pt": "./locales/pt.json",
      "ar": "./locales/ar.json",
      "hi": "./locales/hi.json"
    },
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#FFFBEB"
    }
  }
}